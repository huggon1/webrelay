{
  "name": "webrelay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "backend",
    "extension"
  ],
  "scripts": {
    "build": "npm run build -w @extractor/shared && npm run build -w @extractor/backend && npm run build -w @extractor/extension",
    "test": "npm run test -w @extractor/shared && npm run test -w @extractor/backend",
    "dev:backend": "npm run dev -w @extractor/backend",
    "build:extension": "npm run build -w @extractor/extension"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.306",
    "@types/node": "^22.15.3",
    "esbuild": "^0.25.3",
    "jsdom": "^26.1.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "zod": "^3.24.3"
  }
}

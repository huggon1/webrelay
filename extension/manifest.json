{
  "manifest_version": 3,
  "name": "WebRelay",
  "version": "0.1.0",
  "description": "Run editable local extraction profiles on web pages.",
  "permissions": ["activeTab", "storage", "scripting", "downloads", "clipboardWrite", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WebRelay"
  },
  "commands": {
    "run-last-profile": {
      "suggested_key": {
        "default": "Alt+Shift+E",
        "mac": "Alt+Shift+E"
      },
      "description": "Run the last successful WebRelay profile for this site"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "sandbox": {
    "pages": ["sandbox.html"]
  },
  "content_security_policy": {
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-eval' blob:; worker-src blob:; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
